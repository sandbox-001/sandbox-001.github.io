      "ingredients": [
        {
          "item": "skinless chicken thigh",
          "amount": 1,
          "unit": "Pound"
        },
        {
          "item": "blended chipotle peppers in adobo (brand: San Marcos)",
          "amount": 2,
          "unit": "Tablespoon"
        },
        {
          "item": "garlic powder",
          "amount": 0.33,
          "unit": "Teaspoon"
        },
        {
          "item": "onion powder",
          "amount": 0.33,
          "unit": "Teaspoon"
        },
        {
          "item": "cumin powder",
          "amount": 0.33,
          "unit": "Teaspoon"
        },
        {
          "item": "oregano",
          "amount": 0.33,
          "unit": "Teaspoon"
        },
        {
          "item": "salt",
          "amount": 1,
          "unit": "Teaspoon"
        },
        {
          "item": "black pepper",
          "amount": 1,
          "unit": "pinches"
        }
      ],
      "instructions": [
        {
          "step": 1,
          "text": "Mix the seasoning and adobo"
        },
        {
          "step": 2,
          "text": "Marinate the chicken overnight (12+ hours for enhanced flavor)"
        },
        {
          "step": 3,
          "text": "Coat the chicken in olive oil"
        },
        {
          "step": 4,
          "text": "Bake at 425F for ~40 minutes"
        },
        {
