{
  "recipes": [
    {
      "id": 1,
      "name": "Egg salad",
      "description": "A simple egg salad recipe.",
      "author": "me",
      "image": "/recipes/images/egg_salad.png",
      "ingredients": [
        {
          "item": "eggs",
          "amount": 3,
          "unit": ""
        },
        {
          "item": "green onions (thinly sliced)",
          "amount": 2,
          "unit": ""
        },
        {
          "item": "mayonnaise",
          "amount": 2,
          "unit": "Tablespoon"
        },
        {
          "item": "mustard",
          "amount": 1,
          "unit": "Teaspoon"
        },
        {
          "item": "black pepper",
          "amount": 2,
          "unit": "pinches"
        },
        {
          "item": "salt",
          "amount": 3,
          "unit": "pinches"
        }
      ],
      "instructions": [
        {
          "step": 1,
          "text": "Bring water to a boil"
        },
        {
          "step": 2,
          "text": "Boil eggs for 12 min"
        },
        {
          "step": 3,
          "text": "Put eggs in cold water for 2 min, and then peel"
        },
        {
          "step": 4,
          "text": "Mash the peeled eggs in a bowl with your hands"
        },
        {
          "step": 5,
          "text": "Add the rest of the ingredients in and mix thoroughly"
        }
      ]
    },
    {
