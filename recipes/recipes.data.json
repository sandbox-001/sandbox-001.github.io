      "description": "A sweet and spicy cucumber side dish.",
      "author": "me",
      "image": "/recipes/images/korean_cucumber_salad.png",
      "ingredients": [
        {
          "item": "cucumber",
          "amount": 0.5,
          "unit": "Pound"
        },
        {
          "item": "coarse kosher salt",
          "amount": 0.25,
          "unit": "Tablespoon"
        },
        {
          "item": "gochugaru/고춧가루",
          "amount": 1,
          "unit": "Tablespoon"
        },
        {
          "item": "sugar",
          "amount": 1,
          "unit": "Tablespoon"
        },
        {
          "item": "minced garlic",
          "amount": 1,
          "unit": "Teaspoon"
        },
        {
          "item": "soy sauce",
          "amount": 1,
          "unit": "Tablespoon"
        },
        {
          "item": "sesame oil",
          "amount": 1,
          "unit": "Teaspoon"
        }
      ],
      "instructions": [
        {
          "step": 1,
          "text": "Cut the cucumbers into semicircles, roughly 1/4 inches thick"
        },
        {
          "step": 2,
          "text": "Salt and toss the cucumbers (salting before adding the other stuff enhances texture and flavor)"
        },
        {
          "step": 3,
          "text": "Mix everything else into a sauce"
        },
        {
          "step": 4,
          "text": "Add sauce to cucumbers and toss/mix"
        }
      ]
