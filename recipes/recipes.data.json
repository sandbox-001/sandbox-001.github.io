    {
      "id": 4,
      "name": "만두",
      "description": "A simple, classic Korean dumpling recipe",
      "author": "me",
      "image": "/recipes/images/dumplings.png",
      "ingredients": [
        {
          "item": "dumpling skins",
          "amount": 1,
          "unit": "Pack"
        },
        {
          "item": "ground pork",
          "amount": 1,
          "unit": "Pound"
        },
        {
          "item": "napa cabbage/배추",
          "amount": 1,
          "unit": "Pound"
        },
        {
          "item": "glass noodles/당면",
          "amount": 1,
          "unit": "Ounce"
        },
        {
          "item": "chives",
          "amount": 1,
          "unit": "Handful"
        },
        {
          "item": "green onions",
          "amount": 1,
          "unit": "Handful"
        },
        {
          "item": "minced garlic",
          "amount": 1,
          "unit": "Tablespoon"
        },
        {
          "item": "minced ginger",
          "amount": 0.5,
          "unit": "Teaspoon"
        },
        {
          "item": "soy sauce",
          "amount": 1,
          "unit": "Tablespoon"
        },
        {
          "item": "sesame oil",
          "amount": 1,
          "unit": "Tablespoon"
        },
        {
          "item": "sugar",
          "amount": 1,
          "unit": "Teaspoon"
        },
        {
          "item": "kosher salt",
          "amount": 3,
          "unit": "Teaspoon"
        },
        {
          "item": "black pepper",
          "amount": 1,
          "unit": "Teaspoon"
        }
      ],
      "instructions": [
        {
          "step": 1,
          "text": "Soak glass noodles in cold water (1 hour)"
        },
        {
          "step": 2,
          "text": "Mince napa cabbage and squeeze all of the water out (every last drop)"
        },
        {
          "step": 3,
          "text": "Mince glass noodles"
        },
        {
          "step": 4,
          "text": "Finely chop chives and green onions"
        }
        ,
        {
          "step": 5,
          "text": "Mix garlic, ginger, soy sauce, sesame oil, sugar, kosher salt, black pepper"
        },
        {
          "step": 6,
          "text": "Put everything together and knead with hands/gloves (until the meat protein develops a sticky, tacky paste)"
        },
        {
          "step": 7,
          "text": "Wrap dumplings up"
        },
        {
          "step": 8,
          "text": "Freeze on a baking sheet before putting them into a bag"
        }
      ]
    },
    {
      "id": 5,
      "name": "짜장면",
      "description": "Korean black bean noodles. Eat with danmuji/단무지 and lightly salted sunny side up eggs",
      "author": "me",
      "image": "/recipes/images/jjajangmyeon.png",
      "ingredients": [
        {
          "item": "jjajang powder (brand: Ottogi)",
          "amount": 1,
          "unit": "pack"
        },
        {
          "item": "pork shoulder",
          "amount": 2,
          "unit": "Pounds"
        },
        {
          "item": "onions",
          "amount": 2,
          "unit": ""
        },
        {
          "item": "minced garlic",
          "amount": 2,
          "unit": "Tablespoon"
        },
        {
          "item": "sesame oil",
          "amount": 1,
          "unit": "Tablespoon"
        }
      ],
      "instructions": [
        {
          "step": 1,
          "text": "Marinate the meat in some soy sauce (overnight)"
        },
        {
          "step": 2,
          "text": "Chop the onions into squares (about the size of your thumb fingernail)"
        },
        {
          "step": 3,
          "text": "Mix the jjajang powder and water to make a sludge/slurry (can be adjusted later depending on how thick you want the sauce)"
        },
        {
          "step": 4,
          "text": "Stir fry the meat and minced garlic in a pot until the liquid is reduced (if the meat is tough, pour some water and let it braise for a bit before stir frying again)"
        },
        {
          "step": 5,
          "text": "While there is still a little liquid left, throw the onions in and continue stir frying"
        },
        {
          "step": 6,
          "text": "Pour water into the pot, just enough to barely cover everything"
        },
        {
          "step": 7,
          "text": "Turn off the heat, mix the jjajang slurry and sesame oil in (should have the consistency of a thick porridge, it should pretty much glob off your spoon)"
        },
        {
          "step": 8,
          "text": "Cook some jjajang noodles and mix with jjajang sauce"
        }
      ]
    },
    {
      "id": 6,
      "name": "고추장 돼지불고기",
      "description": "Spicy pork bulgogi. Wrap it up in lettuce with some rice and ssamjang/쌈장",
      "author": "me",
      "image": "/recipes/images/spicy_pork_bulgogi.png",
      "ingredients": [
        {
          "item": "pork shoulder (1/8 inch thick slices)",
          "amount": 1,
          "unit": "Pound"
        },
        {
          "item": "onion (thinly sliced)",
          "amount": 1,
          "unit": ""
        },
        {
          "item": "minced garlic",
          "amount": 2,
          "unit": "Tablespoon"
        },
        {
          "item": "minced ginger",
          "amount": 1,
          "unit": "Teaspoon"
        },
        {
          "item": "gochujang/고추장",
          "amount": 3,
          "unit": "Tablespoon"
        },
        {
          "item": "gochugaru/고춧가루",
          "amount": 1,
          "unit": "Tablespoon"
        },
        {
          "item": "black pepper",
          "amount": 1,
          "unit": "pinch"
        },
        {
          "item": "mirin",
          "amount": 2,
          "unit": "Tablespoon"
        },
        {
          "item": "plum extract/매실청",
          "amount": 2,
          "unit": "Tablespoon"
        },
        {
          "item": "soy sauce",
          "amount": 4,
          "unit": "Tablespoon"
        }
      ],
      "instructions": [
        {
          "step": 1,
          "text": "Prep all the ingredients (except the onions) and mix to make marinade"
        },
        {
          "step": 2,
          "text": "Marinate pork overnight (12+ hours)"
        },
        {
          "step": 3,
          "text": "Get a pot or pan with a lid (needed to braise the pork shoulder a bit to tenderize it further)"
        },
        {
          "step": 4,
          "text": "Cook the pork until it's almost done, then add a little water and cover with a lid (braise on low for ~10 min)"
        },
        {
          "step": 5,
          "text": "Remove the lid, add the sliced onions, and finish cooking"
        }
      ]
    },
    {
      "id": 7,
      "name": "닭죽",
      "description": "Chicken Juk. Has nice chunks of geometric protein. Be prepared to eat a lot of this.",
      "author": "me",
      "image": "/recipes/images/chicken_juk.png",
      "ingredients": [
        {
          "item": "cooked rice",
          "amount": 4,
          "unit": "Cups"
        },
        {
          "item": "chicken breast (cubed roughly 1/2 inch thick)",
          "amount": 4,
          "unit": "Pound"
        },
        {
          "item": "carrots (cubed roughly 1/2 thick)",
          "amount": 1,
          "unit": "Pound"
        },
        {
          "item": "frozen peas",
          "amount": 0.5,
          "unit": "Cup"
        },
        {
          "item": "minced ginger",
          "amount": 0.5,
          "unit": "Teaspoon"
        },
        {
          "item": "minced garlic",
          "amount": 3,
          "unit": "Tablespoon"
        },
        {
          "item": "soy sauce",
          "amount": 0.25,
          "unit": "Cup"
        },
        {
          "item": "salt",
          "amount": 1,
          "unit": "Teaspoon"
        }
      ],
      "instructions": [
        {
          "step": 1,
          "text": "Cube the chicken and marinate with salt and soy sauce (1-2 hours)"
        },
        {
          "step": 2,
          "text": "In a large pot (5.5 quarts) bring some water to a boil (just enough to cover the chicken)"
        },
        {
          "step": 3,
          "text": "Put the chicken into the boiling pot and immediately turn down the heat. Put a lid on the pot and simmer for 30 minutes."
        },
        {
          "step": 4,
          "text": "Put in the carrots, peas, and cooked rice. Make sure to break up the clumps of rice in the pot."
        },
        {
          "step": 5,
          "text": "Add more water, until about an inch covers the top (you can add more water as you keep checking)"
        },
        {
          "step": 7,
          "text": "Put the lid back on and simmer for 1+ hour (stir occasionally)"
        },
        {
          "step": 8,
          "text": "Add more salt or soy sauce if needed. Melt some slices of American cheese in a bowl of juk too."
        }
      ]
    }
  ],
  
  "total": 1
}